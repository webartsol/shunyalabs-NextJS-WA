  "features": {
    "realTimeTranscription": {
      "enabled": true,
      "maxDuration": 3600,
      "supportedFormats": ["mp3", "wav", "m4a", "aac"],
      "maxFileSize": "100MB"
    },
    "medicalTranscription": {
      "enabled": true,
      "hipaaCompliant": true,
      "medicalVocabulary": true,
      "specializedFeatures": ["drug-names", "medical-terms", "patient-data"]
    },
    "textToSpeech": {
      "enabled": true,
      "voiceOptions": ["natural", "robotic", "custom"],
      "supportedLanguages": ["en", "es", "fr", "de", "it"],
      "maxTextLength": 5000
    },
    "sentimentAnalysis": {
      "enabled": true,
      "supportedLanguages": ["en", "es", "fr"],
      "emotionCategories": [
        "positive",
        "negative",
        "neutral",
        "anger",
        "joy",
        "sadness",
        "fear"
      ],
      "confidenceThreshold": 0.7
    },
    "conversationAI": {
      "enabled": true,
      "conversationMemory": true,
      "multiTurnDialogue": true,
      "integrationAPIs": ["webhook", "rest", "websocket"]
    }
  },
  "audio": {
    "sampleRate": 44100,
    "bitRate": 128,
    "channels": 1,
    "format": "mp3",
    "maxDuration": 3600,
    "supportedFormats": ["mp3", "wav", "m4a", "aac", "ogg", "flac"]
  },
  "ui": {
    "theme": {
      "primary": "#3B82F6",
      "secondary": "#10B981",
      "accent": "#8B5CF6",
      "background": "#F9FAFB",
      "text": "#111827"
    },
    "animations": {
      "typingSpeed": 30,
      "bubbleAnimation": true,
      "progressAnimation": true,
      "fadeInDuration": 300
    },
    "layout": {
      "maxWidth": "1200px",
      "responsive": true,
      "mobileFirst": true
    }
  }
}
